{
  "manifest_version": 3,
  "name": "Island Watcher",
  "version": "1.6.1",
  "description": "Track Fortnite island player counts locally and receive peak alerts.",
  "minimum_chrome_version": "109",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen"
  ],
  "host_permissions": [
    "https://fortnite.gg/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Fortnite.GG Island Watcher",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
